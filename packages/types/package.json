{
  "name": "@astro-slides/types",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "Shared TypeScript types for astro-slides, inferred from Zod schemas.",
  "license": "MIT",
  "author": "James Luterek",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./schemas/frontmatter.json": "./schemas/frontmatter.json"
  },
  "dependencies": {
    "zod": "catalog:prod"
  },
  "homepage": "https://jluterek.github.io/astro-slides/",
  "bugs": {
    "url": "https://github.com/jluterek/astro-slides/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jluterek/astro-slides.git",
    "directory": "packages/types"
  },
  "keywords": [
    "astro-slides",
    "presentation",
    "slides",
    "deck",
    "zod",
    "types",
    "schema"
  ],
  "files": [
    "src",
    "schemas",
    "!**/__tests__",
    "!**/*.test.ts"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
