{
  "name": "@astro-slides/client",
  "version": "0.1.2",
  "private": false,
  "type": "module",
  "description": "Runtime UI — layouts, click runtime, transitions, and presenter mode.",
  "license": "MIT",
  "author": "James Luterek",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    },
    "./fit-text": {
      "types": "./src/fit-text.ts",
      "import": "./src/fit-text.ts"
    },
    "./styles/*": "./src/styles/*",
    "./themes/*": "./src/themes/*",
    "./components/*": "./components/*",
    "./layouts/*": "./layouts/*"
  },
  "dependencies": {
    "@astro-slides/types": "workspace:*",
    "@fix-webm-duration/fix": "catalog:frontend",
    "@fontsource-variable/inter": "catalog:frontend",
    "@fontsource/space-grotesk": "catalog:frontend",
    "@shikijs/magic-move": "catalog:frontend",
    "cmdk": "catalog:frontend",
    "drauu": "catalog:frontend",
    "fitty": "catalog:frontend",
    "lz-string": "catalog:frontend",
    "mermaid": "catalog:frontend",
    "nanostores": "catalog:frontend",
    "react-hotkeys-hook": "catalog:frontend",
    "react-resizable-panels": "catalog:frontend",
    "recordrtc": "catalog:frontend",
    "shiki": "catalog:frontend",
    "tinykeys": "catalog:frontend"
  },
  "peerDependencies": {
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend"
  },
  "devDependencies": {
    "@types/react": "catalog:dev",
    "@types/react-dom": "catalog:dev",
    "@types/recordrtc": "catalog:dev",
    "react": "catalog:frontend",
    "react-dom": "catalog:frontend"
  },
  "homepage": "https://jluterek.github.io/astro-slides/",
  "bugs": {
    "url": "https://github.com/jluterek/astro-slides/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jluterek/astro-slides.git",
    "directory": "packages/client"
  },
  "keywords": [
    "astro-slides",
    "presentation",
    "slides",
    "deck",
    "react",
    "layouts",
    "themes",
    "presenter"
  ],
  "files": [
    "src",
    "components",
    "layouts",
    "!**/__tests__",
    "!**/*.test.ts"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
