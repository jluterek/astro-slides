---
import { fmString, type LayoutProps } from "../src/layout-types.ts";
type Props = LayoutProps;
const { slots, frontmatter, title } = Astro.props;
const url = fmString(frontmatter, "url");
---

<div class="slide-layout layout-iframe-right">
  <div class="layout-split">
    <div class="layout-media">
      {url && <iframe src={url} title={title ?? "Embedded content"} loading="lazy" />}
    </div>
    <div class="layout-col" set:html={slots.default ?? ""}></div>
  </div>
</div>
