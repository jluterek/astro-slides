{
  "name": "@astro-slides/mcp-server",
  "version": "0.4.1",
  "private": false,
  "type": "module",
  "description": "Model Context Protocol tool surface for reading, writing, presenting, and exporting decks.",
  "license": "MIT",
  "author": "James Luterek",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "!**/__tests__",
    "!**/*.test.*"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@astro-slides/parser": "workspace:*",
    "@astro-slides/types": "workspace:*",
    "@hono/mcp": "catalog:prod",
    "@hono/node-server": "catalog:prod",
    "@modelcontextprotocol/sdk": "catalog:prod",
    "hono": "catalog:prod",
    "yaml": "catalog:prod",
    "zod": "catalog:prod"
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "tsup": "catalog:dev"
  },
  "homepage": "https://jluterek.github.io/astro-slides/",
  "bugs": {
    "url": "https://github.com/jluterek/astro-slides/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jluterek/astro-slides.git",
    "directory": "packages/mcp-server"
  },
  "keywords": [
    "astro-slides",
    "presentation",
    "slides",
    "deck",
    "mcp",
    "model-context-protocol",
    "ai",
    "agent"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "engines": {
    "node": ">=22.18.0"
  }
