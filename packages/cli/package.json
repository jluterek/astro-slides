{
  "name": "@astro-slides/cli",
  "version": "0.1.0",
  "private": false,
  "type": "module",
  "description": "The astro-slides command \u2014 dev server, build, export, and MCP server entry points.",
  "license": "MIT",
  "author": "James Luterek",
  "bin": {
    "astro-slides": "./bin/astro-slides.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "dependencies": {
    "@astro-slides/core": "workspace:*",
    "@astro-slides/mcp-server": "workspace:*",
    "@astro-slides/parser": "workspace:*",
    "@lillallol/outline-pdf": "catalog:prod",
    "citty": "catalog:prod",
    "jszip": "catalog:prod",
    "listr2": "catalog:prod",
    "pdf-lib": "catalog:prod",
    "pptxgenjs": "catalog:prod",
    "picocolors": "catalog:prod",
    "uqr": "catalog:prod"
  },
  "peerDependencies": {
    "astro": "^5.0.0",
    "@playwright/test": "^1.48.0"
  },
  "peerDependenciesMeta": {
    "@playwright/test": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "catalog:dev",
    "astro": "catalog:frontend"
  },
  "homepage": "https://jluterek.github.io/astro-slides/",
  "bugs": {
    "url": "https://github.com/jluterek/astro-slides/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jluterek/astro-slides.git",
    "directory": "packages/cli"
  },
  "keywords": [
    "astro-slides",
    "presentation",
    "slides",
    "deck",
    "cli",
    "pdf",
    "png",
    "pptx",
    "export",
    "mcp"
  ],
  "files": [
    "bin",
    "dist",
    "src",
    "!**/__tests__",
    "!**/*.test.ts",
    "!**/*.test.js"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
