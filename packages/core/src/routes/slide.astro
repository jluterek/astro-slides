---
import Click from "@astro-slides/client/components/Click.tsx";
import After from "@astro-slides/client/components/After.tsx";
import Clicks from "@astro-slides/client/components/Clicks.tsx";
import FlexBlock from "@astro-slides/client/components/FlexBlock.astro";
import FitText from "@astro-slides/client/components/FitText.astro";
import Grid from "@astro-slides/client/components/Grid.astro";
import HStack from "@astro-slides/client/components/HStack.astro";
import Morph from "@astro-slides/client/components/Morph.astro";
import RenderWhen from "@astro-slides/client/components/RenderWhen.astro";
import Stack from "@astro-slides/client/components/Stack.astro";
import Wrap from "@astro-slides/client/components/Wrap.astro";
import { configs } from "@astro-slides/configs";
import { layouts } from "@astro-slides/layouts";
import { slides } from "@astro-slides/slides";
import "@astro-slides/client/themes/starter/theme.css";
import "@astro-slides/client/styles/deck.css";
import "@astro-slides/client/styles/base.css";
import "@astro-slides/client/styles/layouts.css";
import "@astro-slides/client/styles/primitives.css";
import "@astro-slides/client/styles/click.css";

/**
 * Deck route. Renders the whole deck as a `<section>` stack (current = `present`).
 * Each slide's content is a compiled MDX component per slot; components (`<Click>`,
 * layout primitives, icons) are injected via the MDX `components` prop. The runtime
 * (Phase 04) drives navigation + click stepping client-side.
 */
const COMPONENTS = {
  Click,
  After,
  Clicks,
  Stack,
  HStack,
  Grid,
  Wrap,
  FlexBlock,
  FitText,
  Morph,
  RenderWhen,
};

export function getStaticPaths() {
  const byDeck = new Map<string, typeof slides>();
  for (const s of slides) {
    const list = byDeck.get(s.deck) ?? [];
    list.push(s);
    byDeck.set(s.deck, list);
  }
  return slides.map((slide) => ({
    params: { deck: slide.deck, slide: String(slide.no) },
    props: { current: slide, deckSlides: byDeck.get(slide.deck) ?? [slide] },
  }));
}

const { current, deckSlides } = Astro.props;
const config = configs[current.deck] ?? {};

const [aw, ah] = String(config.aspectRatio ?? "16:9").split(":").map(Number);
const designWidth = Number(config.canvasWidth ?? 1920);
const designHeight = Math.round(designWidth * (aw && ah ? ah / aw : 9 / 16));

const scheme =
  config.colorSchema === "light" || config.colorSchema === "dark" ? config.colorSchema : undefined;

const stateClass = (no: number): string =>
  no < current.no ? "past" : no > current.no ? "future" : "present";

const isImageRef = (v: string): boolean =>
  /^(https?:|\/|\.|data:)/.test(v) || /\.(png|jpe?g|gif|webp|avif|svg)$/i.test(v);
const backgroundStyle = (v: string | null): string | undefined => {
  if (!v) return undefined;
  return isImageRef(v) ? `background-image:url('${v}')` : `background:${v}`;
};

const fallbackLayout = layouts.default ?? layouts["404"];
---

<html lang="en" data-color-scheme={scheme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{current.title ?? `${current.deck} — ${current.no}`}</title>
  </head>
  <body>
    <div
      class="as-deck"
      data-deck={current.deck}
      data-current={current.no}
      data-total={deckSlides.length}
      data-design-width={designWidth}
      data-design-height={designHeight}
    >
      <div class="as-viewport">
        {
          deckSlides.map((s) => {
            const Layout = layouts[s.layout] ?? fallbackLayout;
            const Default = s.slots.default;
            const Left = s.slots.left;
            const Right = s.slots.right;
            return (
              <section
                class:list={["as-slide", stateClass(s.no), s.class]}
                data-slide-no={s.no}
                data-steps={s.totalClicks}
                data-layout={s.layout}
                data-title={s.title ?? ""}
                data-background={s.background ?? undefined}
                style={backgroundStyle(s.background)}
              >
                <Layout no={s.no} title={s.title} layout={s.layout} frontmatter={s.frontmatter}>
                  {Default && <Default components={COMPONENTS} />}
                  {Left && <Left slot="left" components={COMPONENTS} />}
                  {Right && <Right slot="right" components={COMPONENTS} />}
                </Layout>
              </section>
            );
          })
        }
      </div>
      <div class="as-status" aria-live="polite" aria-atomic="true"></div>
    </div>

    <script>
      import { initDeck } from "@astro-slides/client";
      const root = document.querySelector<HTMLElement>(".as-deck");
      if (root) initDeck(root);
    </script>
  </body>
</html>
