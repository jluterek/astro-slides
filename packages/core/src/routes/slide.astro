---
import Click from "@astro-slides/client/components/Click.tsx";
import After from "@astro-slides/client/components/After.tsx";
import Clicks from "@astro-slides/client/components/Clicks.tsx";
import CodeBlock from "@astro-slides/client/components/CodeBlock.astro";
import ShikiMagicMove from "@astro-slides/client/components/ShikiMagicMove.astro";
import KaTeX from "@astro-slides/client/components/KaTeX.astro";
import Mermaid from "@astro-slides/client/components/Mermaid.astro";
import PlantUml from "@astro-slides/client/components/PlantUml.astro";
import FlexBlock from "@astro-slides/client/components/FlexBlock.astro";
import FitText from "@astro-slides/client/components/FitText.astro";
import Grid from "@astro-slides/client/components/Grid.astro";
import HStack from "@astro-slides/client/components/HStack.astro";
import Morph from "@astro-slides/client/components/Morph.astro";
import RenderWhen from "@astro-slides/client/components/RenderWhen.astro";
import Stack from "@astro-slides/client/components/Stack.astro";
import Wrap from "@astro-slides/client/components/Wrap.astro";
// Slidev-compat shims (Phase 15): available in every deck so ported Slidev decks resolve
// their built-in components. `compat: slidev` headmatter is advisory.
import AutoFitText from "@astro-slides/client/components/AutoFitText.astro";
import LightOrDark from "@astro-slides/client/components/LightOrDark.astro";
import Toc from "@astro-slides/client/components/Toc.astro";
import Tweet from "@astro-slides/client/components/Tweet.astro";
import VDrag from "@astro-slides/client/components/VDrag.astro";
import Youtube from "@astro-slides/client/components/Youtube.astro";
import { configs, features } from "@astro-slides/configs";
import { drawings as persistedDrawings } from "@astro-slides/drawings";
import { layouts } from "@astro-slides/layouts";
import { slides } from "@astro-slides/slides";
// KaTeX CSS as a URL asset — linked only when the deck uses math (conditional include).
import katexHref from "katex/dist/katex.min.css?url";
import "@astro-slides/client/themes/starter/theme.css";
import "@astro-slides/client/styles/deck.css";
import "@astro-slides/client/styles/base.css";
import "@astro-slides/client/styles/layouts.css";
import "@astro-slides/client/styles/primitives.css";
import "@astro-slides/client/styles/click.css";
import "@astro-slides/client/styles/transitions.css";
import "@astro-slides/client/styles/code.css";
import "@astro-slides/client/styles/diagrams.css";
import "@astro-slides/client/styles/drawing.css";
import "@shikijs/magic-move/style.css";

/**
 * Deck route. Renders the whole deck as a `<section>` stack (current = `present`).
 * Each slide's content is a compiled MDX component per slot; components (`<Click>`,
 * layout primitives, icons) are injected via the MDX `components` prop. The runtime
 * (Phase 04) drives navigation + click stepping client-side.
 */
const COMPONENTS = {
  Click,
  After,
  Clicks,
  CodeBlock,
  ShikiMagicMove,
  KaTeX,
  Mermaid,
  PlantUml,
  Stack,
  HStack,
  Grid,
  Wrap,
  FlexBlock,
  FitText,
  Morph,
  RenderWhen,
  // Slidev-compat shims.
  Youtube,
  Tweet,
  Toc,
  VDrag,
  AutoFitText,
  LightOrDark,
};

export function getStaticPaths() {
  const byDeck = new Map<string, typeof slides>();
  for (const s of slides) {
    const list = byDeck.get(s.deck) ?? [];
    list.push(s);
    byDeck.set(s.deck, list);
  }
  return slides.map((slide) => ({
    params: { deck: slide.deck, slide: String(slide.no) },
    props: { current: slide, deckSlides: byDeck.get(slide.deck) ?? [slide] },
  }));
}

const { current, deckSlides } = Astro.props;
const config = configs[current.deck] ?? {};
// Drawing overlay (Phase 11): enabled when the deck declares `drawings:`; `persist`
// writes committed strokes to `.astro-slides/drawings/`. Any persisted annotations are
// embedded so the runtime can seed them into the initial shared state.
const drawingsCfg = (config.drawings ?? {}) as { persist?: boolean };
const drawingsEnabled = config.drawings != null;
const deckDrawings = persistedDrawings[current.deck] ?? {};
// Speaker notes per slide (Phase 13): embedded so the PPTX exporter can read them from
// the rendered page (the exporter has no access to the parser AST at runtime).
const deckNotes = Object.fromEntries(deckSlides.map((s) => [s.no, s.notes ?? ""]));
// Conditional asset inclusion (Phase 09): only link KaTeX's stylesheet when the deck
// actually uses math. Mermaid's runtime is code-split and fetched on demand.
const deckFeatures = features[current.deck] ?? {};
const usesKatex = deckFeatures.katex === true;

const [aw, ah] = String(config.aspectRatio ?? "16:9").split(":").map(Number);
const designWidth = Number(config.canvasWidth ?? 1920);
const designHeight = Math.round(designWidth * (aw && ah ? ah / aw : 9 / 16));

const scheme =
  config.colorSchema === "light" || config.colorSchema === "dark" ? config.colorSchema : undefined;

const stateClass = (no: number): string =>
  no < current.no ? "past" : no > current.no ? "future" : "present";

// Resolve a transition (string preset or `{name,duration,easing}` object) into the
// `data-transition` key plus optional per-slide timing CSS vars. Per-slide frontmatter
// overrides the deck default; the deck default keys the root for VT-root cross-fades.
type TransitionValue = string | { name?: string; duration?: number; easing?: string } | undefined;
const deckTransition = config.transition as TransitionValue;
const transitionName = (t: TransitionValue): string =>
  (typeof t === "string" ? t : t?.name) ?? "fade";
const transitionStyle = (t: TransitionValue): string | undefined => {
  if (typeof t !== "object" || !t) return undefined;
  const parts: string[] = [];
  if (t.duration != null) parts.push(`--slide-transition-duration:${t.duration}ms`);
  if (t.easing) parts.push(`--slide-transition-easing:${t.easing}`);
  return parts.length ? parts.join(";") : undefined;
};
const slideTransition = (fm: Record<string, unknown>): TransitionValue =>
  (fm.transition as TransitionValue) ?? deckTransition;

const isImageRef = (v: string): boolean =>
  /^(https?:|\/|\.|data:)/.test(v) || /\.(png|jpe?g|gif|webp|avif|svg)$/i.test(v);
const backgroundStyle = (v: string | null): string | undefined => {
  if (!v) return undefined;
  return isImageRef(v) ? `background-image:url('${v}')` : `background:${v}`;
};

const fallbackLayout = layouts.default ?? layouts["404"];
---

<html lang="en" data-color-scheme={scheme}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{current.title ?? `${current.deck} — ${current.no}`}</title>
    {usesKatex && <link rel="stylesheet" href={katexHref} />}
  </head>
  <body>
    <div
      class="as-deck"
      data-deck={current.deck}
      data-current={current.no}
      data-total={deckSlides.length}
      data-transition={transitionName(deckTransition)}
      data-design-width={designWidth}
      data-design-height={designHeight}
      data-drawings={drawingsEnabled ? "true" : undefined}
      data-drawings-persist={drawingsCfg.persist ? "true" : undefined}
    >
      <div class="as-viewport">
        {
          deckSlides.map((s) => {
            const Layout = layouts[s.layout] ?? fallbackLayout;
            const Default = s.slots.default;
            const Left = s.slots.left;
            const Right = s.slots.right;
            const t = slideTransition(s.frontmatter);
            const style = [backgroundStyle(s.background), transitionStyle(t)]
              .filter(Boolean)
              .join(";");
            return (
              <section
                class:list={["as-slide", stateClass(s.no), s.class]}
                data-slide-no={s.no}
                data-steps={s.totalClicks}
                data-layout={s.layout}
                data-title={s.title ?? ""}
                data-transition={transitionName(t)}
                data-background={s.background ?? undefined}
                data-export-as={s.frontmatter?.exportAs === "image" ? "image" : undefined}
                style={style || undefined}
              >
                <Layout no={s.no} title={s.title} layout={s.layout} frontmatter={s.frontmatter}>
                  {Default && <Default components={COMPONENTS} />}
                  {Left && <Left slot="left" components={COMPONENTS} />}
                  {Right && <Right slot="right" components={COMPONENTS} />}
                </Layout>
              </section>
            );
          })
        }
      </div>
      <div class="as-status" aria-live="polite" aria-atomic="true"></div>
      {
        drawingsEnabled && (
          <script
            type="application/json"
            class="as-drawings-data"
            set:html={JSON.stringify(deckDrawings)}
          />
        )
      }
      <script type="application/json" class="as-notes-data" set:html={JSON.stringify(deckNotes)} />
    </div>

    <script>
      import { initDeck } from "@astro-slides/client";
      import { syncGateway } from "@astro-slides/runtime-config";
      // In dev with --remote, advertise the WS gateway so the runtime also joins over
      // WebSocket (cross-origin: phones + a second screen). Null in static builds.
      if (syncGateway)
        (window as unknown as { __ASTRO_SLIDES_SYNC__?: string }).__ASTRO_SLIDES_SYNC__ =
          syncGateway;
      const root = document.querySelector<HTMLElement>(".as-deck");
      if (root) initDeck(root);
    </script>
  </body>
</html>
