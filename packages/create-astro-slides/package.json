{
  "name": "create-astro-slides",
  "version": "0.1.1",
  "private": false,
  "type": "module",
  "description": "Scaffold a new astro-slides deck project — pnpm create astro-slides <target>.",
  "license": "MIT",
  "author": "James Luterek",
  "bin": {
    "create-astro-slides": "./bin/create-astro-slides.mjs"
  },
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "bin",
    "dist",
    "src",
    "!**/__tests__",
    "!**/*.test.ts",
    "!**/*.test.js"
  ],
  "dependencies": {
    "@clack/prompts": "catalog:prod",
    "picocolors": "catalog:prod"
  },
  "devDependencies": {
    "@types/node": "catalog:dev"
  },
  "homepage": "https://jluterek.github.io/astro-slides/",
  "bugs": {
    "url": "https://github.com/jluterek/astro-slides/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jluterek/astro-slides.git",
    "directory": "packages/create-astro-slides"
  },
  "keywords": [
    "astro-slides",
    "presentation",
    "slides",
    "deck",
    "create",
    "scaffold",
    "starter",
    "generator"
  ],
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "engines": {
    "node": ">=22.18.0"
  }
}
