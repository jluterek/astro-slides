{
  "name": "astro-slides-monorepo",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "A web-native presentation framework built on Astro, TypeScript, and MDX, with a first-class MCP server.",
  "license": "MIT",
  "author": "James Luterek",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=24",
    "pnpm": ">=10"
  },
  "scripts": {
    "build": "pnpm --filter @astro-slides/mcp-server build",
    "typecheck": "tsc -b",
    "lint": "biome lint",
    "lint:fix": "biome lint --write",
    "format": "biome format --write",
    "format:check": "biome format",
    "check": "biome check",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "gen:schemas": "node packages/types/scripts/gen-schemas.ts",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "pnpm build && changeset publish",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx,mjs,cjs,json,jsonc}": "biome check --no-errors-on-unmatched"
  },
  "devDependencies": {
    "@biomejs/biome": "catalog:dev",
    "@changesets/changelog-github": "catalog:dev",
    "@changesets/cli": "catalog:dev",
    "@playwright/test": "catalog:dev",
    "@vitest/coverage-v8": "catalog:dev",
    "husky": "catalog:dev",
    "jsdom": "catalog:dev",
    "lint-staged": "catalog:dev",
    "typescript": "catalog:dev",
    "vitest": "catalog:dev"
  }
}
